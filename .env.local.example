# ── Primary AI provider ──────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# Powers AI analysis + live web search for current tool pricing
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Fallback AI provider ─────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
# Used automatically if Anthropic is unavailable or key is not set
# Analysis based on training data (no live web search in fallback mode)
GOOGLE_API_KEY=your_google_ai_key_here
